# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=itemsforsale.in
DATA_MODE=local
NEXT_ALLOWED_DEV_ORIGINS=192.168.1.21,localhost

# Local PostgreSQL
# Set DATA_MODE=postgres to use the local PostgreSQL store instead of data/local-db.json
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itemsforsale

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Local admin session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
ADMIN_SESSION_SECRET=replace_me_for_real_deployments
