{
  "name": "itemsforsale",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/e2e/run-all.mjs",
    "test:e2e:admin": "node scripts/e2e/flows/admin-flow.mjs",
    "test:e2e:admin-auth-guard": "node scripts/e2e/flows/admin-auth-guard-flow.mjs",
    "test:e2e:admin-create-validation": "node scripts/e2e/flows/admin-create-validation-flow.mjs",
    "test:e2e:admin-delete": "node scripts/e2e/flows/admin-delete-flow.mjs",
    "test:e2e:admin-image-validation": "node scripts/e2e/flows/admin-image-validation-flow.mjs",
    "test:e2e:admin-rate-limit": "node scripts/e2e/flows/admin-rate-limit-flow.mjs",
    "test:e2e:admin-session": "node scripts/e2e/flows/admin-session-flow.mjs",
    "test:e2e:admin-slug-regression": "node scripts/e2e/flows/admin-slug-regression-flow.mjs",
    "test:e2e:public-bulk-interest": "node scripts/e2e/flows/public-bulk-interest-flow.mjs",
    "test:e2e:public-contact": "node scripts/e2e/flows/public-contact-flow.mjs",
    "test:e2e:public-lead": "node scripts/e2e/flows/public-lead-flow.mjs",
    "test:e2e:public-location-fallback": "node scripts/e2e/flows/public-location-fallback-flow.mjs",
    "test:e2e:human-check-refresh": "node scripts/e2e/flows/human-check-refresh-flow.mjs",
    "test:e2e:public-rate-limit": "node scripts/e2e/flows/public-rate-limit-flow.mjs",
    "test:e2e:export-throttle": "node scripts/e2e/flows/export-throttle-flow.mjs",
    "test:e2e:catalogue-render": "node scripts/e2e/flows/catalogue-render-flow.mjs",
    "test:e2e:item-detail-render": "node scripts/e2e/flows/item-detail-render-flow.mjs",
    "test:e2e:about-seller": "node scripts/e2e/flows/about-seller-flow.mjs",
    "test:e2e:csv-export": "node scripts/e2e/flows/csv-export-flow.mjs",
    "test:e2e:admin-leads-view": "node scripts/e2e/flows/admin-leads-view-flow.mjs",
    "test:e2e:system-status": "node scripts/e2e/flows/system-status-flow.mjs",
    "test:e2e:startup-schema": "node scripts/e2e/flows/startup-schema-flow.mjs",
    "test:e2e:cleanup-resilience": "node scripts/e2e/flows/cleanup-resilience-flow.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate:constraints": "node --env-file=.env.local scripts/migrate-postgres-constraints.mjs",
    "db:import": "node --env-file=.env.local scripts/import-json-to-postgres.mjs",
    "db:seed:dev": "node --env-file=.env.local scripts/seed-dev-fake-data.mjs",
    "db:seed:cleanup": "node --env-file=.env.local scripts/cleanup-dev-fake-data.mjs",
    "db:recreate": "node --env-file=.env.local scripts/recreate-postgres-db.mjs",
    "db:recreate:seed": "node --env-file=.env.local scripts/recreate-postgres-db.mjs --seed",
    "dev:seed": "npm run db:seed:dev && npm run dev"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "next": "16.1.7",
    "pg": "^8.16.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sharp": "^0.34.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
